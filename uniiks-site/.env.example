# Resend API key — create at https://resend.com/api-keys
RESEND_API_KEY=

# Destination for form submissions
CONTACT_TO_EMAIL=admin@uniikscare.com

# Verified sender in Resend. Until you verify a domain, you can use:
#   UNIIKS Website <onboarding@resend.dev>
# After domain verification, switch to e.g.:
#   UNIIKS Website <no-reply@uniikscare.com>
CONTACT_FROM_EMAIL="UNIIKS Website <onboarding@resend.dev>"
